# ====================================================
# MANA EVENTS – ENVIRONMENT TEMPLATE
# ====================================================

# --- Core Infrastructure ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_secret_here_32_chars
CRON_SECRET=mana_cron_secret_7d2f8e1a9c3b

# --- Database (PostgreSQL) ---
# For local development with Docker:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mana_db?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/mana_db?schema=public"

# --- Redis (BullMQ & Caching) ---
# Local Docker Redis
REDIS_URL="redis://localhost:6379"
# Upstash (Optional if REDIS_URL is provided)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Authentication (JWT) ---
JWT_ACCESS_SECRET=mana-event-secret-key-1234567890
JWT_REFRESH_SECRET=mana-event-refresh-secret-key-0987654321

# --- Search (Meilisearch) ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey
MEILISEARCH_VENDORS_INDEX=vendors

# --- Payments (Razorpay) ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Emails (Resend) ---
RESEND_API_KEY=re_123456789

# --- Storage (Cloudinary) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Notifications (Firebase FCM) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Background Jobs (Inngest) ---
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=local

# --- Maps (Google Maps) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- SMS (Twilio - Optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Socket.io ---
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# --- Observability (Optional) ---
LOG_LEVEL=info
SLACK_WEBHOOK_URL=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
